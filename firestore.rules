rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user has admin privileges
    function isAdmin() {
      return request.auth != null && (
        (request.auth.token.email_verified == true && request.auth.token.email in ["admin@leetcode.com", "juan@test.com", "admin@test.com", "dungpubgame@gmail.com", "24110215@st.vju.ac.vn"]) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"))
      );
    }

    // Rules for the users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    // Rules for the problems collection
    match /problems/{problemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for the threads collection
    match /threads/{threadId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rules for the submissions collection (Strict ownership check)
    match /submissions/{submissionId} {
      allow read: if request.auth != null && (resource == null || resource.data.uid == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid || isAdmin();
      allow delete: if isAdmin();
    }

    // Rules for the notifications collection
    match /notifications/{notifId} {
      allow read: if request.auth != null && resource.data.toUid == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.toUid == request.auth.uid || resource.data.fromUid == request.auth.uid);
    }

    // Rules for the follows collection
    match /follows/{followId} {
      allow read: if true;
      allow create, delete: if request.auth != null;
    }

    // Rules for the deleted_problems collection
    match /deleted_problems/{problemId} {
      allow read, write: if isAdmin();
    }

    // Contest Ecosystem Rules
    
    // Contests collection
    match /contests/{contestId} {
      allow read: if true;
      allow write: if isAdmin();

      // Contest discussions rules
      match /discussions/{discussionId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
        allow update, delete: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      }
    }

    // Contest Problems collection
    match /contest_problems/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contest Participants collection (Prevent self-unterminating)
    match /contest_participants/{id} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && (
        (resource.data.uid == request.auth.uid && resource.data.status != "terminated" && request.resource.data.uid == request.auth.uid) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Contest Submissions collection (Lock read to solver during active contests)
    match /contest_submissions/{id} {
      allow read: if request.auth != null && (
        resource == null || 
        resource.data.uid == request.auth.uid || 
        isAdmin() || 
        (exists(/databases/$(database)/documents/contests/$(resource.data.contestId)) && 
         get(/databases/$(database)/documents/contests/$(resource.data.contestId)).data.status == "ended")
      );
      allow create: if request.auth != null && 
        request.resource.data.uid == request.auth.uid &&
        (!exists(/databases/$(database)/documents/contest_participants/$(request.resource.data.contestId + "_" + request.auth.uid)) ||
         get(/databases/$(database)/documents/contest_participants/$(request.resource.data.contestId + "_" + request.auth.uid)).data.status != "terminated");
      allow update, delete: if isAdmin();
    }

    // Contest Announcements collection
    match /contest_announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contest Clarifications collection (Prevent reading private clarifications of others)
    match /contest_clarifications/{id} {
      allow read: if resource == null || resource.data.isPublic == true || (request.auth != null && (resource.data.uid == request.auth.uid || isAdmin()));
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Contest Leaderboard collection
    match /contest_leaderboard/{id} {
      allow read: if true;
      allow write: if isAdmin() || (request.auth != null && request.resource.data.uid == request.auth.uid);
    }

    // Contest Integrity Events collection
    match /contest_integrity_events/{id} {
      allow read: if isAdmin();
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Contest Editorial collection
    match /contest_editorial/{contestId} {
      allow read: if isAdmin() || (
        exists(/databases/$(database)/documents/contests/$(contestId)) && 
        get(/databases/$(database)/documents/contests/$(contestId)).data.status == "ended"
      );
      allow write: if isAdmin();
    }

    // Contest Statistics collection
    match /contest_statistics/{contestId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Drafts and Contest Drafts
    match /drafts/{draftId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.uid == request.auth.uid) && request.resource.data.uid == request.auth.uid;
    }
    match /contest_drafts/{draftId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.uid == request.auth.uid) && request.resource.data.uid == request.auth.uid;
    }
  }
}
